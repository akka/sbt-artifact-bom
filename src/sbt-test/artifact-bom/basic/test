# compile triggers makeBom automatically; verify the BOM file is created with correct content
> compile
$ exists artifact-bom/sample-app/pom.xml
> checkBom

# record mtime, sleep so the filesystem clock can move, re-run makeBom; with the cache key matching
# the file must not be rewritten
> recordBomMtime
$ sleep 1500
> makeBom
> checkBomNotRegenerated

# delete the cache file but leave the BOM in place; makeBom must detect identical content
# and leave the file untouched (preserving mtime)
> deleteBomCache
$ sleep 1500
> makeBom
> checkBomNotRegenerated

# delete the BOM and the cache; makeBom must recreate the file
$ delete artifact-bom/sample-app/pom.xml
> deleteBomCache
> makeBom
$ exists artifact-bom/sample-app/pom.xml
> checkBom
